<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="RadioBloom.Maui.MainPage"
             BackgroundColor="#F4F6F8"
             Title="JustRadio">
    <Grid x:Name="RootLayout" Padding="24" ColumnSpacing="22" RowSpacing="16">
        <Grid.GestureRecognizers>
            <TapGestureRecognizer Tapped="OnPageTapped" />
        </Grid.GestureRecognizers>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Row="0" Grid.Column="0" Padding="22" BackgroundColor="#FFFFFF" Stroke="#E3EAF1" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <Grid ColumnSpacing="20">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="220" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Padding="14" BackgroundColor="#F8FAFC" Stroke="#E3EAF1" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Label Text="REGION PREVIEW" FontAttributes="Bold" FontSize="11" CharacterSpacing="2" TextColor="#8794A6" />
                        <Border Grid.Row="1" HeightRequest="126" StrokeThickness="0" BackgroundColor="#DCEBF4">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <AbsoluteLayout x:Name="MapLayout" IsClippedToBounds="True">
                                <GraphicsView x:Name="MapFallbackView"
                                              AbsoluteLayout.LayoutBounds="0,0,1,1"
                                              AbsoluteLayout.LayoutFlags="All" />
                                <AbsoluteLayout x:Name="MapTileLayer"
                                                AbsoluteLayout.LayoutBounds="0,0,1,1"
                                                AbsoluteLayout.LayoutFlags="All" />
                                <BoxView BackgroundColor="#DCEBF4"
                                         Opacity="0.18"
                                         AbsoluteLayout.LayoutBounds="0,0,1,1"
                                         AbsoluteLayout.LayoutFlags="All" />
                                <Border x:Name="MapLabel"
                                        Padding="12,5"
                                        BackgroundColor="#F8FCFF"
                                        Stroke="#DCEBFA"
                                        AbsoluteLayout.LayoutBounds="0.08,0.18,190,30"
                                        AbsoluteLayout.LayoutFlags="PositionProportional">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="15" />
                                    </Border.StrokeShape>
                                    <Label x:Name="MapLabelText" Text="Automatic location" FontAttributes="Bold" FontSize="12" TextColor="#31597C" LineBreakMode="TailTruncation" />
                                </Border>
                                <Border x:Name="MapPin"
                                        WidthRequest="14"
                                        HeightRequest="14"
                                        BackgroundColor="#31597C"
                                        Stroke="#FFFFFF"
                                        StrokeThickness="2"
                                        AbsoluteLayout.LayoutBounds="0.53,0.39,14,14"
                                        AbsoluteLayout.LayoutFlags="PositionProportional">
                                    <Border.StrokeShape>
                                        <RoundRectangle CornerRadius="7" />
                                    </Border.StrokeShape>
                                </Border>
                            </AbsoluteLayout>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="1" Padding="14" BackgroundColor="#F8FAFC" Stroke="#E3EAF1" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <Grid RowSpacing="8">
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>
                        <Label Text="WEATHER" FontAttributes="Bold" FontSize="11" CharacterSpacing="2" TextColor="#8794A6" />
                        <Border Grid.Row="1" Padding="18,14" BackgroundColor="#F0F6FC" StrokeThickness="0">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="16" />
                            </Border.StrokeShape>
                            <VerticalStackLayout Spacing="8">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Label Text="CURRENT" FontAttributes="Bold" FontSize="11" CharacterSpacing="2" TextColor="#8794A6" />
                                    <Border Grid.Column="1" Padding="10,4" BackgroundColor="#F7FBFF" Stroke="#D8E5F1" StrokeThickness="1">
                                        <Border.StrokeShape>
                                            <RoundRectangle CornerRadius="12" />
                                        </Border.StrokeShape>
                                        <Label x:Name="WeatherBadgeLabel" Text="Syncing" FontAttributes="Bold" FontSize="11" TextColor="#45637E" />
                                    </Border>
                                </Grid>
                                <Label x:Name="WeatherTempLabel" Text="--" FontAttributes="Bold" FontSize="40" TextColor="#152433" />
                                <Label x:Name="WeatherConditionLabel" Text="Loading local weather..." FontAttributes="Bold" FontSize="14" TextColor="#334155" LineBreakMode="TailTruncation" />
                            </VerticalStackLayout>
                        </Border>
                    </Grid>
                </Border>

                <Border Grid.Column="2" Padding="14" BackgroundColor="#F8FAFC" Stroke="#E3EAF1" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="18" />
                    </Border.StrokeShape>
                    <VerticalStackLayout Spacing="10">
                        <Label Text="STATION REGION" FontAttributes="Bold" FontSize="11" CharacterSpacing="2" TextColor="#8794A6" />
                        <Border Padding="12,0" BackgroundColor="#FFFFFF" Stroke="#DCE5EE" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnCountrySelectorTapped" />
                            </Border.GestureRecognizers>
                            <Grid HeightRequest="38" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label x:Name="CountryValueLabel" Text="Country" VerticalOptions="Center" FontSize="14" TextColor="#1F2937" LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1" Text="v" VerticalOptions="Center" FontSize="12" TextColor="#667085" />
                            </Grid>
                        </Border>
                        <Border Padding="12,0" BackgroundColor="#FFFFFF" Stroke="#DCE5EE" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="13" />
                            </Border.StrokeShape>
                            <Border.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnRegionSelectorTapped" />
                            </Border.GestureRecognizers>
                            <Grid HeightRequest="38" ColumnSpacing="10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <Label x:Name="RegionValueLabel" Text="All regions" VerticalOptions="Center" FontSize="14" TextColor="#1F2937" LineBreakMode="TailTruncation" />
                                <Label Grid.Column="1" Text="v" VerticalOptions="Center" FontSize="12" TextColor="#667085" />
                            </Grid>
                        </Border>
                        <HorizontalStackLayout Spacing="8">
                            <Button Text="Apply" HeightRequest="34" CornerRadius="16" BackgroundColor="#111827" TextColor="#FFFFFF" Clicked="OnApplyLocationClicked" />
                            <Button Text="Auto" HeightRequest="34" CornerRadius="16" BackgroundColor="#FFFFFF" BorderColor="#DCE5EE" BorderWidth="1" TextColor="#34495E" Clicked="OnAutoLocationClicked" />
                        </HorizontalStackLayout>
                        <Border x:Name="SelectorDropdown" IsVisible="False" Padding="8" BackgroundColor="#FFFFFF" Stroke="#DCE5EE" StrokeThickness="1">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Border.Shadow>
                                <Shadow Brush="#1A334155" Offset="0,6" Radius="14" Opacity="0.12" />
                            </Border.Shadow>
                            <CollectionView x:Name="SelectorOptionsView"
                                            SelectionMode="None"
                                            BackgroundColor="Transparent"
                                            VerticalScrollBarVisibility="Never"
                                            MaximumHeightRequest="180"
                                            ItemSizingStrategy="MeasureFirstItem">
                                <CollectionView.ItemsLayout>
                                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="4" />
                                </CollectionView.ItemsLayout>
                                <CollectionView.ItemTemplate>
                                    <DataTemplate>
                                        <Border Padding="12,0" HeightRequest="38" BackgroundColor="#FFFFFF" Stroke="#EDF2F7" StrokeThickness="1">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="12" />
                                            </Border.StrokeShape>
                                            <Border.GestureRecognizers>
                                                <TapGestureRecognizer Tapped="OnSelectorOptionTapped" CommandParameter="{Binding .}" />
                                            </Border.GestureRecognizers>
                                            <Label Text="{Binding .}"
                                                   VerticalOptions="Center"
                                                   FontSize="13"
                                                   TextColor="#1F2937"
                                                   HorizontalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation" />
                                        </Border>
                                    </DataTemplate>
                                </CollectionView.ItemTemplate>
                            </CollectionView>
                        </Border>
                    </VerticalStackLayout>
                </Border>
            </Grid>
        </Border>

        <Border Grid.Row="1" Grid.Column="0" Padding="16" BackgroundColor="#FFFFFF" Stroke="#E3EAF1" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <VerticalStackLayout Spacing="12">
                <VerticalStackLayout Spacing="4">
                    <Label x:Name="SummaryLabel" Text="Loading nearby stations..." FontAttributes="Bold" FontSize="15" TextColor="#40526A" />
                    <Label x:Name="LocationLabel" Text="Automatic location" FontSize="12" TextColor="#8492A6" />
                </VerticalStackLayout>
                <ScrollView Orientation="Horizontal" HorizontalScrollBarVisibility="Never">
                    <HorizontalStackLayout x:Name="CategoryPanel" Spacing="8" />
                </ScrollView>
                <Border x:Name="SearchContainer" Padding="12,0" HeightRequest="44" BackgroundColor="#F8FAFC" Stroke="#DCE5EE" StrokeThickness="1">
                    <Border.StrokeShape>
                        <RoundRectangle CornerRadius="14" />
                    </Border.StrokeShape>
                    <Grid ColumnSpacing="8">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Entry x:Name="SearchBox"
                               Placeholder="Search stations"
                               TextChanged="OnSearchTextChanged"
                               Completed="OnSearchCompleted"
                               ReturnType="Search"
                               TextColor="#1F2937"
                               PlaceholderColor="#8492A6"
                               BackgroundColor="Transparent"
                               FontSize="14"
                               HeightRequest="44"
                               VerticalOptions="Center" />
                        <Button x:Name="ClearSearchButton"
                                Grid.Column="1"
                                Text="Clear"
                                IsVisible="False"
                                HeightRequest="32"
                                Padding="12,0"
                                CornerRadius="14"
                                BackgroundColor="#FFFFFF"
                                BorderColor="#DCE5EE"
                                BorderWidth="1"
                                TextColor="#34495E"
                                Clicked="OnClearSearchClicked" />
                    </Grid>
                </Border>
            </VerticalStackLayout>
        </Border>

        <Border Grid.Row="2" Grid.Column="0" Padding="12" BackgroundColor="#FFFFFF" Stroke="#E3EAF1" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="22" />
            </Border.StrokeShape>
            <CollectionView x:Name="StationCollection"
                            SelectionMode="None"
                            BackgroundColor="Transparent"
                            ItemSizingStrategy="MeasureFirstItem"
                            VerticalScrollBarVisibility="Always">
                <CollectionView.ItemsLayout>
                    <LinearItemsLayout Orientation="Vertical" ItemSpacing="0" />
                </CollectionView.ItemsLayout>
                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="14,6">
                            <Border Padding="18" BackgroundColor="#FCFDFE" Stroke="#E6ECF3" StrokeThickness="1">
                                <Border.StrokeShape>
                                    <RoundRectangle CornerRadius="18" />
                                </Border.StrokeShape>
                                <Border.Shadow>
                                    <Shadow Brush="#1A334155" Offset="0,2" Radius="8" Opacity="0.16" />
                                </Border.Shadow>
                                <Border.Triggers>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#F7FBFF" />
                                        <Setter Property="Stroke" Value="#A9CBE3" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                    <DataTrigger TargetType="Border" Binding="{Binding IsHovered}" Value="True">
                                        <Setter Property="BackgroundColor" Value="#FFFFFF" />
                                        <Setter Property="Stroke" Value="#D2E3F0" />
                                        <Setter Property="StrokeThickness" Value="2" />
                                    </DataTrigger>
                                </Border.Triggers>
                                <Border.GestureRecognizers>
                                    <PointerGestureRecognizer PointerEntered="OnStationPointerEntered" PointerExited="OnStationPointerExited" />
                                    <TapGestureRecognizer Tapped="OnStationTapped" CommandParameter="{Binding .}" />
                                </Border.GestureRecognizers>
                                <Grid ColumnSpacing="14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <VerticalStackLayout Spacing="6">
                                        <Label Text="{Binding Name}" FontAttributes="Bold" FontSize="18" TextColor="#1F2937" LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding Location}" FontSize="13" TextColor="#667085" LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding Tagline}" FontSize="14" TextColor="#344054" LineBreakMode="TailTruncation" MaxLines="1" />
                                        <Label Text="{Binding MetadataSummary}" FontSize="12" TextColor="#7A8A9E" LineBreakMode="TailTruncation" MaxLines="1" />
                                    </VerticalStackLayout>
                                    <HorizontalStackLayout Grid.Column="1" Spacing="8" VerticalOptions="Start" HorizontalOptions="End">
                                        <Button Text="{Binding FavoriteButtonText}"
                                                WidthRequest="78"
                                                HeightRequest="44"
                                                Padding="10,0"
                                                CornerRadius="14"
                                                BackgroundColor="#FFFFFF"
                                                BorderColor="#DCE5EE"
                                                BorderWidth="1"
                                                TextColor="#34495E"
                                                FontAttributes="Bold"
                                                FontSize="12"
                                                Clicked="OnStationFavoriteClicked"
                                                CommandParameter="{Binding .}">
                                            <Button.Triggers>
                                                <DataTrigger TargetType="Button" Binding="{Binding IsFavorite}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#FFF7ED" />
                                                    <Setter Property="BorderColor" Value="#FDBA74" />
                                                    <Setter Property="TextColor" Value="#9A3412" />
                                                </DataTrigger>
                                            </Button.Triggers>
                                        </Button>
                                        <Border WidthRequest="120"
                                                HeightRequest="44"
                                                Padding="12,0"
                                                BackgroundColor="#EFF5FB"
                                                Stroke="#E1E9F2">
                                            <Border.StrokeShape>
                                                <RoundRectangle CornerRadius="14" />
                                            </Border.StrokeShape>
                                            <Border.Triggers>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsSelected}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#E4F0FB" />
                                                    <Setter Property="Stroke" Value="#C4D8EA" />
                                                </DataTrigger>
                                                <DataTrigger TargetType="Border" Binding="{Binding IsHovered}" Value="True">
                                                    <Setter Property="BackgroundColor" Value="#ECF5FD" />
                                                    <Setter Property="Stroke" Value="#D3E2EF" />
                                                </DataTrigger>
                                            </Border.Triggers>
                                            <Label Text="{Binding Genre}"
                                                   FontSize="12"
                                                   TextColor="#42617F"
                                                   HorizontalTextAlignment="Center"
                                                   VerticalTextAlignment="Center"
                                                   LineBreakMode="TailTruncation"
                                                   MaxLines="1" />
                                        </Border>
                                    </HorizontalStackLayout>
                                </Grid>
                            </Border>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>
            </CollectionView>
        </Border>

        <Border Grid.Row="0" Grid.RowSpan="3" Grid.Column="1" Padding="24" BackgroundColor="#FFFFFF" Stroke="#E3EAF1" StrokeThickness="1">
            <Border.StrokeShape>
                <RoundRectangle CornerRadius="24" />
            </Border.StrokeShape>
            <ScrollView>
                <VerticalStackLayout Spacing="18">
                    <Grid ColumnSpacing="10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <Border Padding="14,7" HorizontalOptions="Start" BackgroundColor="#EFF6FF" Stroke="#DCEBFA">
                            <Border.StrokeShape>
                                <RoundRectangle CornerRadius="14" />
                            </Border.StrokeShape>
                            <Label x:Name="StatusLabel" Text="Ready" FontAttributes="Bold" FontSize="12" TextColor="#31597C" />
                        </Border>
                        <Button x:Name="SelectedFavoriteButton"
                                Grid.Column="1"
                                Text="Save"
                                IsEnabled="False"
                                HeightRequest="36"
                                Padding="14,0"
                                CornerRadius="16"
                                BackgroundColor="#FFFFFF"
                                BorderColor="#DCE5EE"
                                BorderWidth="1"
                                TextColor="#34495E"
                                FontAttributes="Bold"
                                FontSize="12"
                                Clicked="OnSelectedFavoriteClicked" />
                    </Grid>
                    <Label Text="LISTENING NOW" FontAttributes="Bold" FontSize="11" CharacterSpacing="2" TextColor="#8794A6" />
                    <Label x:Name="NowTitleLabel" Text="Select a station" FontAttributes="Bold" FontSize="30" TextColor="#17202A" />
                    <Label x:Name="NowSubtitleLabel" Text="Choose a station from the list." FontSize="14" TextColor="#667085" />
                    <Border Padding="16" BackgroundColor="#F6FAFE" Stroke="#E3EAF1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="6">
                            <Label Text="TRACK" FontAttributes="Bold" FontSize="11" CharacterSpacing="2" TextColor="#8794A6" />
                            <Label x:Name="TrackLabel" Text="Artist and title will appear here when playback starts." FontSize="15" TextColor="#1F2937" />
                        </VerticalStackLayout>
                    </Border>
                    <Label x:Name="DescriptionLabel" Text="This first MAUI version focuses on cross-platform layout, station loading, and basic playback." FontSize="14" TextColor="#475467" />
                    <Border Padding="16" BackgroundColor="#F6FAFE" Stroke="#E3EAF1">
                        <Border.StrokeShape>
                            <RoundRectangle CornerRadius="18" />
                        </Border.StrokeShape>
                        <VerticalStackLayout Spacing="8">
                            <Label Text="LIVE LEVEL" FontAttributes="Bold" FontSize="11" CharacterSpacing="2" TextColor="#8794A6" />
                            <GraphicsView x:Name="EqualizerView" HeightRequest="88" />
                        </VerticalStackLayout>
                    </Border>
                    <HorizontalStackLayout Spacing="10">
                        <Button x:Name="PlayButton" Text="Play" HeightRequest="44" CornerRadius="20" BackgroundColor="#111827" TextColor="#FFFFFF" Clicked="OnPlayClicked" />
                        <Button x:Name="StopButton" Text="Stop" HeightRequest="44" CornerRadius="20" BackgroundColor="#FFFFFF" BorderColor="#DCE5EE" BorderWidth="1" TextColor="#34495E" Clicked="OnStopClicked" />
                    </HorizontalStackLayout>
                    <Label x:Name="SourceLabel" Text="Source metadata will appear here." FontSize="12" TextColor="#77869A" />
                </VerticalStackLayout>
            </ScrollView>
        </Border>

        <WebView x:Name="AudioWebView" Grid.Row="0" Grid.Column="0" HeightRequest="1" WidthRequest="1" Opacity="0.01" InputTransparent="True" />
    </Grid>
</ContentPage>
